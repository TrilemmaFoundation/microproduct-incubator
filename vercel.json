{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "redirects": [
    {
      "source": "/:path*",
      "destination": "https://build.trilemma.foundation/:path*",
      "permanent": false,
      "has": [{ "type": "host", "value": "microproducts.trilemma.foundation" }]
    },
    {
      "source": "/docs/showcase/microproducts",
      "destination": "/showcase",
      "permanent": true
    },
    {
      "source": "/docs/showcase/microproducts/",
      "destination": "/showcase",
      "permanent": true
    },
    {
      "source": "/docs/contribute/how-to-contribute",
      "destination": "/contribute",
      "permanent": true
    },
    {
      "source": "/docs/contribute/how-to-contribute/",
      "destination": "/contribute",
      "permanent": true
    }
  ]
}
